
{% capture pill %}
<div class="single-pill">
    {{ settings.title }}
    {% if settings.text !=blank %}
     {{ settings.text }}
     {% endif %}
</div>
{% endcapture %}

{{ pill }}

{% schema %}
{
  "name": "CB Pill",
  "class": "featured-card-block",
  "settings": [

    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
   
    {
      "type": "richtext",
      "id": "text",
      "label": "Sub-Text"
    }

  ],
  "presets": [
    {
      "name": "CB Pill",
      "category": "CB"
    }
  ]
}
{% endschema %}