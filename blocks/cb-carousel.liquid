{% comment %}
  blokcks: cb-media-carousel.liquid (drag/throw version)
  - Drag/throw carousel (no autoplay)
  - Choose columns per breakpoint (desktop up to 5)
  - Overflows to right edge of the screen (viewport bleed)
  - Preserves existing block rendering: we wrap each direct child of {{ children }} into slides via JS
{% endcomment %}

{% liquid
  assign block_id = block.id
  assign heading = block.settings.heading
%}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}


<div id="cb-media-carousel-{{ block_id }}" class="kmc  color-{{ block.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}">
  <div class="kmc__inner">
    {% if heading != blank %}
      <div class="kmc__heading">
        <h2>{{ heading }}</h2>
      </div>
    {% endif %}

   <!-- Slider main container -->
<div class="swiper{% if block.settings.show_arrows %} carousel-has-arrows-{{ block_id }}{% endif %}" id="swiper-{{ block_id }}">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper group-block--height-fill">
    <!-- Slides -->
   {{ children }}
  </div>

  <!-- If we need pagination -->
  {% if block.settings.show_dots %}
  <div class="swiper-pagination"></div>
  {% else %}
       <!-- If we need scrollbar -->
  <div class="swiper-scrollbar"></div>
  {% endif %}

  <!-- If we need navigation buttons -->
 {% if block.settings.show_arrows %}
  <div class="swiper-button-prev"></div>
  <div class="swiper-button-next"></div>
{% endif %}

 

  
</div>

  </div>
</div>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
<script>
  (function() {
    const el = document.getElementById('swiper-{{ block_id }}');
    if (!el) return;
    new Swiper(el, {
      slidesPerView: {{ block.settings.slides_default }},
      spaceBetween: {{ block.settings.space_default }},
      {% if block.settings.show_arrows %}
      navigation: {
        nextEl: '#swiper-{{ block_id }} .swiper-button-next',
        prevEl: '#swiper-{{ block_id }} .swiper-button-prev',
      },
      {% endif %}
      {% if block.settings.show_dots %}
      pagination: {
        el: '#swiper-{{ block_id }} .swiper-pagination',
        clickable: true,
      },
      {% endif %}
      breakpoints: {
        320: {
          slidesPerView: {{ block.settings.slides_320 }},
          spaceBetween: {{ block.settings.space_320 }}
        },
        768: {
          slidesPerView: {{ block.settings.slides_768 }},
          spaceBetween: {{ block.settings.space_768 }}
        },
        990: {
          slidesPerView: {{ block.settings.slides_990 }},
          spaceBetween: {{ block.settings.space_990 }}
        },
        1280: {
          slidesPerView: {{ block.settings.slides_1280 }},
          spaceBetween: {{ block.settings.space_1280 }}
        }
      }
    });
  })();
</script>
<style>
  
  .kmc__heading{
  margin-bottom:18px;
  text-align:center;}


.cb-media-carousel-block{
    max-width:100%;
    width:100%;}
.kmc__inner.full-width .swiper{
padding-inline-start: var(--util-page-margin-offset);
scroll-padding-inline-start: var(--util-page-margin-offset);
padding-inline-end: var(--util-page-margin-offset);}

/* 1) Make Swiper stretch slides to tallest card */
.kmc .swiper-wrapper {
  align-items: stretch;         /* key: equal heights across row */
}

/* 2) Let each slide participate in stretching */
.kmc .swiper-slide {
  height: auto;                 /* don't lock slide height */
  display: flex;                /* so inner card can stretch */
}
@media screen and (max-width:768px){
.kmc .carousel-has-arrows-{{ block_id }} .swiper-slide {
    padding-left: 40px;
    padding-right: 40px;
}
}

/* Swiper */
#swiper-{{ block_id }}{padding-bottom:30px;}
.carousel-has-arrows-{{ block_id }}{}

/* Hide default Swiper arrow pseudo-element when a custom image is slotted in */
#swiper-{{ block_id }} .swiper-navigation-icon{
  display: none!important;
}

/* Size and fit the custom image within the button container */
#swiper-{{ block_id }} .swiper-button-prev,
#swiper-{{ block_id }} .swiper-button-next {
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  height: 17px;
  width: 13px;}


#swiper-{{ block_id }} .swiper-button-prev { background-image: url('{{ block.settings.left_arrow | image_url }}');}
#swiper-{{ block_id }} .swiper-button-next{ background-image: url('{{ block.settings.right_arrow | image_url }}');}


#swiper-{{ block_id }} .swiper-pagination-bullet{background:{{ block.settings.dot_color }};}
#swiper-{{ block_id }} .swiper-pagination-bullet-active{background:{{ block.settings.dot_color_active }};}

</style>
{% schema %}
{
  "name": "CB Carousel",
  "tag": "div",
  "class": "cb-media-carousel-block",
  "settings": [
    { "type": "header", "content": "Controls" },
{
  "type": "checkbox",
  "id": "show_arrows",
  "label": "Show arrows",
  "default": true
},
{
  "type": "image_picker",
  "id": "left_arrow",
  "label": "Left arrow"
},
{
  "type": "image_picker",
  "id": "right_arrow",
  "label": "Right arrow"
},
{
  "type": "checkbox",
  "id": "show_dots",
  "label": "Show dots",
  "default": false
},

{
  "type": "color",
  "id": "dot_color",
  "label": "Dot Color"
},
{
  "type": "color",
  "id": "dot_color_active",
  "label": "Active Dot Color"
},

     { "type": "header", "content": "Defaults" },
    { "type": "range", "id": "slides_default", "label": "Slides per view (default)", "min": 1, "max": 10, "step": 0.1, "default": 1 },
    { "type": "range", "id": "space_default",  "label": "Space between (px, default)", "min": 0, "max": 48, "step": 1, "default": 10 },

    { "type": "header", "content": "Breakpoint: ≥ 320px" },
    { "type": "range", "id": "slides_320", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 1.2 },
    { "type": "range", "id": "space_320",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 768px" },
    { "type": "range", "id": "slides_768", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 3.2 },
    { "type": "range", "id": "space_768",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 990px" },
    { "type": "range", "id": "slides_990", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 4.2 },
    { "type": "range", "id": "space_990",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 1280px" },
    { "type": "range", "id": "slides_1280", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 5 },
    { "type": "range", "id": "space_1280",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "text", 
      "id": "heading", 
      "label": "Heading" },

    { "type": "header", 
      "content": "t:content.block_layout" },
    {
      "type": "select",
      "id": "block_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },



    { "type": "header", 
      "content": "t:content.padding" },
    {
      "type": "range",
       "id": "padding-block-start",
        "label": "t:settings.top",
      "min": 0,
       "max": 100, 
      "step": 1,
       "unit": "px", 
       "default": 0
    },
    {
      "type": "range",
       "id": "padding-block-end", 
       "label": "t:settings.bottom",
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 0
    }
  ],
  "blocks": [
    { "type": "cb-slide" },
    { "type": "group" }
  ],
  "presets": [
    { "name": "CB Carousel", "category": "Layout" }
  ]
}
{% endschema %}
