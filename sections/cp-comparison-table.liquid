{%- liquid
  assign table = section.settings.comparison_table
  if table == blank
    if request.design_mode
      assign show_placeholder = true
    else
      echo ''
    endif
  endif
-%}

{% if show_placeholder %}
  <div class="comparison-table__placeholder">
    <p>Assign a Comparison Table metaobject in the section settings.</p>
  </div>
{% elsif table != blank %}

<section
  class="comparison-table"
  id="comparison-table-{{ section.id }}"
  data-section-id="{{ section.id }}"
>

    <div class="comparison-table-top">
{% assign image = section.settings.comparison_table_blob  %}

{% if image != blank %}
  {% assign image_height = height | default: image.height %}
  {% assign image_height_2x = height | default: image_height | times: 2 %}
  {% assign image_height_3x = height | default: image_height | times: 3 %}

  {% capture image_srcset -%}
    {{ image | image_url: height: image_height }} 1x, {{ image | image_url: height: image_height_2x }} 2x, {{ image | image_url: height: image_height_3x }} 3x
  {%- endcapture %}

  {% assign style_value = style | default: '' %}

  {% if unset_image_tag %}
    {% assign style_value = style_value | append: 'object-position: inherit;' %}
  {% endif %}

  {{ image | image_url: height: image_height | image_tag: class: class, srcset: image_srcset, style: style_value }}
{% elsif text_fallback %}
  {{ text_fallback }}
{% endif %}

 {% content_for 'blocks' %}

    </div>
  <div class="comparison-table__card">

    {%- for row in table.rows.value -%}

      {%- comment -%} 
          Resolve each column's display value.
          Priority: image → number → text → check_x (boolean, nil-safe)
       {%- endcomment -%}

 {%- liquid
        assign c2_image   = row.column_2_image.value
        assign c3_image   = row.column_3_image.value
        assign c2_number  = row.column_2_number.value
        assign c3_number  = row.column_3_integer.value
        assign c2_text    = row.column_2_text.value
        assign c3_text    = row.column_3_text.value
        assign c2_bool    = row.column_2_check_x.value
        assign c3_bool    = row.column_3_check_x.value
        assign c1_title   = row.column_1_title.value
        assign c1_sub     = row.column_1_title_subtitle.value
  -%}
       {%- comment -%} Is this the header row? Images in col 2 or col 3 trigger header layout. {%- endcomment -%}
   {%- liquid
        if c2_image != blank or c3_image != blank
          assign is_header = true
        else
          assign is_header = false
        endif
      -%}

      {%- if is_header -%}

        {%- comment -%} ── Header row ─────────────────────────────────────────── {%- endcomment -%}
        <div class="ct-header">

          <div class="ct-header__label">
         
            {%- if c1_title != blank -%}
              <span class="ct-label__main">{{ c1_title }}</span>
            {%- endif -%}
            
       
          </div>

          <div class="ct-header__better ct-col--better">
            <div class="ct-header__better-inner">
              {%- if c2_image != blank -%}
                <img
                  src="{{ c2_image | image_url: width: 300 }}"
                  alt="{{ c2_image.alt | default: 'Product image' }}"
                  width="150"
                  loading="eager"
                  class="ct-header__product-img"
                >
              {%- endif -%}
            </div>
          </div>

          <div class="ct-header__competitor">
            {%- if c3_text != blank -%}
              <span class="ct-header__competitor-check" aria-hidden="true">✓</span>
              <span class="ct-header__competitor-label">{{ c3_text }}</span>
            {%- endif -%}
            {%- if c3_image != blank -%}
              <img
                src="{{ c3_image | image_url: width: 240 }}"
                alt="{{ c3_image.alt | default: 'Competitor image' }}"
                width="120"
                loading="eager"
                class="ct-header__competitor-img"
              >
            {%- endif -%}
          </div>

        </div>

      {%- else -%}

        {%- comment -%} ── Data row ───────────────────────────────────────────── {%- endcomment -%}
        <div class="ct-row">

          {%- comment -%} Label cell {%- endcomment -%}
          <div class="ct-cell ct-cell--label">
            {%- if c1_title != blank -%}
              <span class="ct-label__main">{{ c1_title }}</span>
            {%- endif -%}
            {%- if c1_sub != blank -%}
              <span class="ct-label__sub">{{ c1_sub }}</span>
            {%- endif -%}
          </div>

          {%- comment -%} Better (col 2) cell {%- endcomment -%}
          <div class="ct-cell ct-cell--better ct-col--better">
            {%- if c2_number != blank -%}
              <span class="ct-val ct-val--number">{{ c2_number }}</span>
            {%- elsif c2_text != blank -%}
              <span class="ct-val ct-val--text">{{ c2_text }}</span>
            {%- elsif c2_bool != nil -%}
              {%- if c2_bool -%}
                <span class="ct-icon ct-icon--check" aria-label="Yes">
                <svg width="37" height="39" viewBox="0 0 37 39" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M15.1029 38.5621L0.290509 20.8976C-0.565111 19.8773 0.629984 18.4305 1.79356 19.078L12.507 25.0403C13.0059 25.3179 13.6312 25.2057 14.0024 24.7719L34.8291 0.431857C35.7639 -0.660612 37.4794 0.515812 36.7971 1.78144L17.0787 38.3605C16.6764 39.1069 15.6478 39.2119 15.1029 38.5621Z" fill="#F7DB09"/>
</svg>

                </span>
              {%- else -%}
                <span class="ct-icon ct-icon--x" aria-label="No">
                    <svg width="37" height="38" viewBox="0 0 37 38" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M3.33887 33.6543L33.3907 3.6543" stroke="#EE362F" stroke-width="7" stroke-linecap="round"/>
<path d="M33.3905 33.6543L3.33867 3.6543" stroke="#EE362F" stroke-width="7" stroke-linecap="round"/>
</svg>

                </span>
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- comment -%} Competitor (col 3) cell {%- endcomment -%}
          <div class="ct-cell ct-cell--competitor">
            {%- if c3_number != blank -%}
              <span class="ct-val ct-val--number">{{ c3_number }}</span>
            {%- elsif c3_text != blank -%}
              <span class="ct-val ct-val--text">{{ c3_text }}</span>
            {%- elsif c3_bool != nil -%}
              {%- if c3_bool -%}
                <span class="ct-icon ct-icon--check ct-icon--check-competitor" aria-label="Yes">
                <svg width="37" height="39" viewBox="0 0 37 39" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M15.1029 38.5621L0.290509 20.8976C-0.565111 19.8773 0.629984 18.4305 1.79356 19.078L12.507 25.0403C13.0059 25.3179 13.6312 25.2057 14.0024 24.7719L34.8291 0.431857C35.7639 -0.660612 37.4794 0.515812 36.7971 1.78144L17.0787 38.3605C16.6764 39.1069 15.6478 39.2119 15.1029 38.5621Z" fill="#F7DB09"/>
</svg>

                </span>
              {%- else -%}
              
                   <span class="ct-icon ct-icon--x" aria-label="No">
                  <svg width="37" height="38" viewBox="0 0 37 38" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M3.33887 33.6543L33.3907 3.6543" stroke="#EE362F" stroke-width="7" stroke-linecap="round"/>
<path d="M33.3905 33.6543L3.33867 3.6543" stroke="#EE362F" stroke-width="7" stroke-linecap="round"/>
</svg>

                </span>
              {%- endif -%}
            {%- endif -%}
          </div>

        </div>

      {%- endif -%}
    {%- endfor -%}

  </div>
</section>

{% endif %}

{% stylesheet %}
/* ── CSS custom properties ─────────────────────────────────────── */
.comparison-table {
  --ct-cream:      #FBF6E9;
  --ct-teal:       #115157;
  --ct-gold:       #F7DB09;
  --ct-red:        #EE362F;
  --ct-text:       #115157;
  --ct-row-alt:    #fff;
  --ct-radius:     30px;
  --ct-font-head:  'Petrona';
  --ct-font-body:  'Petrona';

  padding: 40px 20px;
  background: var(--ct-cream);
  font-family: var(--ct-font-body);
}

/* -- Thermo --------*/
.comparison-table-top{
    margin: 0 auto 100px auto;
    max-width: 760px;
    position:relative;
}

.comparison-table-top > img{
    bottom: -200px;
    position: absolute;
    width: 250px;
}
.comparison-table-top .single-thermo {margin-left: auto;}
.comparison-table-top .single-thermo .image-wrap{background-color: var(--ct-teal);}
.comparison-table-top .single-thermo .thermo-content{
    background-color: var(--ct-teal);
    margin-left: 0;
    margin-right: -35px;
    padding: 18px 40px 18px 21px;}
.comparison-table-top .single-thermo{flex-direction: row-reverse;}

@media (min-width: 600px) {
    .comparison-table-top .single-thermo .thermo-content{padding-right:  50px;}
}

/* ── Card wrapper ────────────────────────────────────────────────── */
.comparison-table__card {
  max-width: 760px;
  margin: 0 auto;
  border-radius: var(--ct-radius);
  overflow: hidden;
    position: relative;
}

/* ── Shared grid ─────────────────────────────────────────────────── */
.ct-header,
.ct-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
}

/* ── Better (teal) column colouring ─────────────────────────────── */
.ct-col--better,
.ct-cell--better {
  background: var(--ct-teal);
  border-top: 1px solid var(--ct-row-alt);
}

/* ── Header ──────────────────────────────────────────────────────── */
.ct-header {
  align-items: flex-end;
}

.ct-header__label {
    background: #fff;
    border: 1px solid var(--ct-teal);
    border-right: none;
    border-top-left-radius: var( --ct-radius);
    padding: 17px 16px 14px 26px;
}

.ct-header__better {
    border-top:none;
  display: flex;
  justify-content: center;
}

.ct-header__better-inner {
  background: var(--ct-teal);
  border-radius: var(--ct-radius) 0 0 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20px 16px 0;
  width: 100%;
}

@media (min-width: 600px) {
   .ct-header__better-inner{border-radius: var(--ct-radius) var(--ct-radius) 0 0;}
}

.ct-header__product-img {
  height: 120px;
  width: auto;
  object-fit: contain;
  display: block;
}

.ct-header__competitor {
    background: #fff;
    border: 1px solid var(--ct-teal);
    border-top-right-radius:  var( --ct-radius);
    border-left: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 20px 12px 12px;
  gap: 6px;
  
}
@media (min-width: 600px) {
    .ct-header__competitor{width:150px;}
}


.ct-header__competitor .ct-cell--label{border-top-left-radius: var(--ct-radius);}

.ct-header__competitor-check {
  font-size: 1.4rem;
  color: var(--ct-red);
  font-weight: 700;
}

.ct-header__competitor-label {
  font-family: var(--ct-font-body);
  font-weight: 600;
  font-size: 0.78rem;
  color: var(--ct-red);
  text-align: center;
  line-height: 1.35;
}

.ct-header__competitor-img {
  height: 90px;
  width: auto;
  object-fit: contain;
  display: block;
  opacity: 0.85;
}

/* ── Data rows ───────────────────────────────────────────────────── */

.ct-row .ct-cell--competitor{
      border-right: 1px solid var(--ct-teal);
}

/* Alternating row background for label + competitor cells */
.ct-row:nth-child(odd) .ct-cell--label,
.ct-row:nth-child(odd) .ct-cell--competitor,
.ct-row:nth-child(even) .ct-cell--label,
.ct-row:nth-child(even) .ct-cell--competitor {
  background: var(--ct-row-alt);
}

/* Round top of teal column on first row */
.ct-header__better {
  border-radius: var(--ct-radius) var(--ct-radius) 0 0;
}

 .ct-cell--label,
 .ct-cell--competitor{ border-bottom: 1px solid var(--ct-teal);}

.ct-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 10px;
}

.ct-cell--label {
 border-left: 1px solid var(--ct-teal);
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 18px 20px 14px 26px;
  gap: 0;
}


.ct-row:last-of-type .ct-cell--label{border-bottom-left-radius: var(--ct-radius);}
.ct-row:last-of-type .ct-cell--competitor{border-bottom-right-radius: var(--ct-radius);}

@media (min-width: 600px) {
    .ct-cell--competitor{width:150px;}
}

/* ── Label text ──────────────────────────────────────────────────── */
.ct-label__main {
  font-family: var(--ct-font-head);
  font-weight: 700;
  font-size: 1.2rem;
  color: var(--ct-text);
  line-height: 1.3;
}

.ct-label__sub {
  font-size: 0.74rem;
  color: #666;
}

/* ── Cell values ─────────────────────────────────────────────────── */
.ct-val--number {
  font-family: var(--ct-font-head);
  font-weight: 900;
  font-size: 2.1rem;
  line-height: 1;
}

.ct-cell--better   .ct-val--number { color: var(--ct-gold); }
.ct-cell--competitor .ct-val--number { color: var(--ct-red);  }

.ct-val--text {
  font-family: var(--ct-font-body);
  font-weight: 600;
  font-size: 0.88rem;
  text-align: center;
  line-height: 1.3;
}

.ct-cell--better   .ct-val--text { color: var(--ct-gold); }
.ct-cell--competitor .ct-val--text { color: var(--ct-red);  }

/* ── Icons ───────────────────────────────────────────────────────── */
.ct-icon {
  width: 34px;
  height: 34px;
  
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.ct-icon--check {
height: 24px;
    width: 23px;
}

.ct-icon--x {
    height: 15px;
width: 15px;
}

/* ── Placeholder (editor only) ──────────────────────────────────── */
.comparison-table__placeholder {
  padding: 40px;
  text-align: center;
  color: #888;
  font-size: 0.9rem;
  border: 2px dashed #ccc;
  border-radius: 8px;
  margin: 20px;
}

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 520px) {
  .ct-header__product-img  { height: 80px; }
  .ct-header__competitor-img { height: 66px; }
  .ct-val--number          { font-size: 1.6rem; }
  .ct-label__main          { font-size: 0.8rem; }
  .ct-cell--label          { padding: 12px 14px; }
  .ct-val--text            { font-size: 0.78rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "CB Comparison Table",
  "tag": "section",
  "class": "comparison-table-section",
  "settings": [
    {
      "type": "metaobject",
      "id": "comparison_table",
      "label": "Comparison Table",
      "metaobject_type": "comparison_table"
    },
     {
      "type": "image_picker",
      "id": "comparison_table_blob",
      "label": "Image Blob "
    }
  ],
   "blocks": [
    {
      "type": "cb-thermo"
    }
  ],
  "presets": [
    {
      "name": "CB Comparison Table"
    }
  ]
}
{% endschema %}
