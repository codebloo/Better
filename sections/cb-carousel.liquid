{% comment %}
  Section: cb-media-carousel.liquid (drag/throw version)
  - Drag/throw carousel (no autoplay)
  - Choose columns per breakpoint (desktop up to 5)
  - Overflows to right edge of the screen (viewport bleed)
  - Preserves existing block rendering: we wrap each direct child of {{ children }} into slides via JS
{% endcomment %}

{% liquid
  assign section_id = section.id
  assign heading = section.settings.heading
%}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section id="cb-media-carousel-{{ section_id }}" class="kmc section section--{{ section.settings.section_width }}
  color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}">
  <div class="kmc__inner {{ section.settings.section_width }}">
    {% if heading != blank %}
      <div class="kmc__heading">
        <h2>{{ heading }}</h2>
      </div>
    {% endif %}

   <!-- Slider main container -->
<div class="swiper" id="swiper-{{ section_id }}">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper group-block--height-fill">
    <!-- Slides -->
   {{ children }}
  </div>

  <!-- If we need pagination -->
  {% if section.settings.show_dots %}
  <div class="swiper-pagination"></div>
  {% endif %}

  <!-- If we need navigation buttons -->
  {% if section.settings.show_arrows %}
  <div class="swiper-button-prev"></div>
  <div class="swiper-button-next"></div>
  {% endif %}

  <!-- If we need scrollbar -->
  <div class="swiper-scrollbar"></div>

  
</div>

  </div>
</section>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
<script>
  (function() {
    const el = document.getElementById('swiper-{{ section_id }}');
    if (!el) return;
    new Swiper(el, {
      slidesPerView: {{ section.settings.slides_default }},
      spaceBetween: {{ section.settings.space_default }},
      {% if section.settings.show_arrows %}
      navigation: {
        nextEl: '#swiper-{{ section_id }} .swiper-button-next',
        prevEl: '#swiper-{{ section_id }} .swiper-button-prev',
      },
      {% endif %}
      {% if section.settings.show_dots %}
      pagination: {
        el: '#swiper-{{ section_id }} .swiper-pagination',
        clickable: true,
      },
      {% endif %}
      breakpoints: {
        320: {
          slidesPerView: {{ section.settings.slides_320 }},
          spaceBetween: {{ section.settings.space_320 }}
        },
        768: {
          slidesPerView: {{ section.settings.slides_768 }},
          spaceBetween: {{ section.settings.space_768 }}
        },
        990: {
          slidesPerView: {{ section.settings.slides_990 }},
          spaceBetween: {{ section.settings.space_990 }}
        },
        1280: {
          slidesPerView: {{ section.settings.slides_1280 }},
          spaceBetween: {{ section.settings.space_1280 }}
        }
      }
    });
  })();
</script>
<style>.kmc__heading{
  margin-bottom:18px;
  text-align:center;}


.kmc__inner.full-width{ 
  padding:0;} 
.kmc__inner.full-width .swiper{
padding-inline-start: var(--util-page-margin-offset);
scroll-padding-inline-start: var(--util-page-margin-offset);
padding-inline-end: var(--util-page-margin-offset);}

/* 1) Make Swiper stretch slides to tallest card */
.kmc .swiper-wrapper {
  align-items: stretch;         /* key: equal heights across row */
}

/* 2) Let each slide participate in stretching */
.kmc .swiper-slide {
  height: auto;                 /* don't lock slide height */
  display: flex;                /* so inner card can stretch */
}

#swiper-{{ section_id }} .swiper-pagination-bullet{background:{{ section.settings.dot_color }};}
#swiper-{{ section_id }} .swiper-pagination-bullet-active{background:{{ section.settings.dot_color_active }};}

</style>
{% schema %}
{
  "name": "CB Carousel",
  "tag": "section",
  "class": "cb-media-carousel-section",
  "settings": [
    { "type": "header", "content": "Controls" },
{
  "type": "checkbox",
  "id": "show_arrows",
  "label": "Show arrows",
  "default": true
},
{
  "type": "image_picker",
  "id": "left_arrow",
  "label": "Left arrow"
},
{
  "type": "image_picker",
  "id": "right_arrow",
  "label": "Right arrow"
},
{
  "type": "checkbox",
  "id": "show_dots",
  "label": "Show dots",
  "default": false
},

{
  "type": "color",
  "id": "dot_color",
  "label": "Dot Color"
},
{
  "type": "color",
  "id": "dot_color_active",
  "label": "Active Dot Color"
},

     { "type": "header", "content": "Defaults" },
    { "type": "range", "id": "slides_default", "label": "Slides per view (default)", "min": 1, "max": 10, "step": 0.1, "default": 1 },
    { "type": "range", "id": "space_default",  "label": "Space between (px, default)", "min": 0, "max": 48, "step": 1, "default": 10 },

    { "type": "header", "content": "Breakpoint: ≥ 320px" },
    { "type": "range", "id": "slides_320", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 1.2 },
    { "type": "range", "id": "space_320",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 768px" },
    { "type": "range", "id": "slides_768", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 3.2 },
    { "type": "range", "id": "space_768",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 990px" },
    { "type": "range", "id": "slides_990", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 4.2 },
    { "type": "range", "id": "space_990",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "header", "content": "Breakpoint: ≥ 1280px" },
    { "type": "range", "id": "slides_1280", "label": "Slides per view", "min": 1, "max": 10, "step": 0.1, "default": 5 },
    { "type": "range", "id": "space_1280",  "label": "Space between (px)", "min": 0, "max": 48, "step": 1, "default": 18 },

    { "type": "text", 
      "id": "heading", 
      "label": "Heading" },

    { "type": "header", 
      "content": "t:content.section_layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },



    { "type": "header", 
      "content": "t:content.padding" },
    {
      "type": "range",
       "id": "padding-block-start",
        "label": "t:settings.top",
      "min": 0,
       "max": 100, 
      "step": 1,
       "unit": "px", 
       "default": 0
    },
    {
      "type": "range",
       "id": "padding-block-end", 
       "label": "t:settings.bottom",
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 0
    }
  ],
  "blocks": [
    { "type": "cb-slide" },
    { "type": "group" }
  ],
  "max_blocks": 50,
  "presets": [
    { "name": "CB Carousel", "category": "Layout" }
  ]
}
{% endschema %}
